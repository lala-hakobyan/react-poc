{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Next.js: debug server-side",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm run dev",
        "cwd": "${workspaceFolder}/apps/note-app-nextjs"
      },
      {
        "name": "Next.js: debug client-side",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:3000",
        "webRoot": "${workspaceFolder}/apps/note-app-nextjs"
      },
      {
        "name": "API Layer: Server",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm run server",
        "cwd": "${workspaceFolder}/apps/note-app-nextjs"
      }
    ],
    "compounds": [
    {
      "name": "Full Stack: All",
      "configurations": [
        "Next.js: debug server-side",
        "Next.js: debug client-side",
        "API Layer: Server"
      ]
    }
  ]
  }